# Vimeo personal access token (server-side only).
# Required scopes: read access to the authenticated account's videos.
# The browser never receives this value — it is read exclusively in
# lib/vimeo.ts / app/api/vimeo/route.ts via process.env.
VIMEO_TOKEN=

# --- Jira Cloud (server-side only) ---
# Read-only Dev Reporting integration. The browser never receives these — they
# are read exclusively in lib/jira.ts / app/api/jira/route.ts via process.env.
# JIRA_API_TOKEN is an Atlassian API token (id.atlassian.com → Security → API
# tokens). Note: a token carries the full permissions of the account that owns
# it; for hard read-only, use a service account with only "Browse Projects".
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=service-account@your-org.com
JIRA_API_TOKEN=
# Comma-separated project keys to report on (the prefix on issue keys).
JIRA_PROJECT_KEYS=DEV,OPS
# Story-points custom field id. Instances may expose more than one such field;
# pin the correct one. Find ids at: GET /rest/api/3/field
JIRA_STORY_POINTS_FIELD=customfield_10016

# Anthropic API key (server-side only), used ONLY by the Jira CLI's
# `--summarize` flag to generate per-user occupation summaries via Claude
# (claude-opus-4-8). Read exclusively in lib/summarize.ts. Without it, plain
# `npm run jira` and the web app work fine; only `--summarize` requires it.
ANTHROPIC_API_KEY=

# GitHub personal access token (server-side only) for Dev Reporting.
# Scopes: `repo` (read) to include private repos + `read:org`.
# Read only in lib/github.ts (web) and scripts/github.ts (CLI); never sent
# to the browser. Without it, GET /api/github returns 500 and the CLI exits 1.
GH_ACCESS_TOKEN=

# --- Slack (server-side only) ---
# Bot/user token for the Policy Tracking reader and the Field QA CLI. Read
# exclusively in lib/slack.ts / app/api/policy/route.ts via process.env; never
# sent to the browser. Scopes: channels:history + groups:history (private
# channels) + users:read + files:read. files:read is required so the field-qa
# CLI can download the stats-bot daily summary image from #field-qa. Without it,
# GET /api/policy live mode returns 500 and the CLI exits 1.
SLACK_TOKEN=
# Workspace subdomain (the "<x>" in https://<x>.slack.com), used to build
# message permalinks in reports. Optional — when unset, permalinks are empty.
SLACK_WORKSPACE=
# OUTWARD POSTING (the verdict publisher, `npm run field-publish`): the ONLY
# feature that writes into the workspace. It is DRY-RUN by default and prints
# what it would post; an actual `--publish` requires the **chat:write** scope
# added to the bot + reinstall, and the bot must be a member of the target
# channel. Until chat:write is granted, dry-run works fully; `--publish` errors
# with a clear scope message. Post to a private test channel before #field-qa.
#
# EVENTS WEBHOOK (the automatic reaction, app/api/slack/events): Slack signs
# every event POST; the route verifies it with this secret (Basic Information →
# App Credentials → Signing Secret). Without it the route fails closed (500).
# Required only for the deployed event-based bot; the CLIs don't need it.
SLACK_SIGNING_SECRET=

# --- Google Drive (server-side only) ---
# Base64-encoded Google service-account key JSON (restricted to Drive read-only
# scope). Used by lib/drive.ts to fetch exports and metadata; never sent to the
# browser. The CLI runs Node with `--conditions=react-server` so the server-only
# import resolves to its empty module. Without it, `npm run drive --...` and
# Drive-related API routes fail.
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Vercel Cron (server-side only) ---
# Shared secret guarding the scheduled routes (/api/cron/sync, /api/cron/verdict).
# Vercel injects `Authorization: Bearer <CRON_SECRET>` on scheduled invocations
# when this is set in the project env; the routes reject anything else (and fail
# closed when unset). Set it in Vercel; the CLIs don't need it. Schedules live in
# vercel.json — daily by default (Hobby allows daily crons only; tighten the sync
# cadence to */15 or hourly on Pro).
CRON_SECRET=

# --- Console auth (Sign in with Slack / OIDC) ---
# The console gates all dashboard pages + data API routes behind a Slack login
# (allowlist in lib/allowedUsers.ts). Create a Slack app with the OpenID Connect
# scopes (openid, email, profile) and register the redirect URL
# <AUTH_BASE_URL>/api/auth/callback under OAuth & Permissions.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Random secret (>=32 bytes) used to HMAC-sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
# Public base URL used to build the OAuth redirect_uri. Local: http://localhost:3003
# Prod: the deployed origin (e.g. https://ops.example.com). No trailing slash.
AUTH_BASE_URL=http://localhost:3003
