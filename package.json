{
  "name": "orients-ops-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3003",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "vimeo": "node --conditions=react-server --import tsx scripts/vimeo.ts",
    "github": "node --conditions=react-server --import tsx scripts/github.ts",
    "jira": "node --conditions=react-server --import tsx scripts/jira.ts",
    "fieldops": "node --conditions=react-server --import tsx scripts/fieldops.ts",
    "field-qa": "node --conditions=react-server --import tsx scripts/fieldQa.ts",
    "policy": "node --conditions=react-server --import tsx scripts/policy.ts",
    "slack-sync": "node --conditions=react-server --import tsx scripts/slack-sync.ts",
    "field-verdict": "node --conditions=react-server --import tsx scripts/field-verdict.ts",
    "field-publish": "node --conditions=react-server --import tsx scripts/field-publish.ts",
    "field-ask": "node --conditions=react-server --import tsx scripts/field-ask.ts",
    "field-remember": "node --conditions=react-server --import tsx scripts/field-remember.ts",
    "field-approvals": "node --conditions=react-server --import tsx scripts/field-approvals.ts",
